@using AssetManagementSystem.Web.ViewModels.Locations
@model LocationCreateViewModel

@{
    ViewData["Title"] = "Create Location";
}

<div class="container">
    <div class="gap-2 mb-4 pb-2 border-bottom">
        <h1 class="h3 fw-bold text-primary mb-1">Add New Location</h1>
        <p class="text-muted mb-0">Create a new physical location.</p>
    </div>

    <form asp-action="Create" method="post" novalidate>
        <div class="row g-4">
            <div class="col-lg-8">
                <div class="card shadow border-0 h-100">
                    <div class="card-body">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                        <div class="mb-3">
                            <label asp-for="Name" class="form-label fw-semibold"></label>
                            <input asp-for="Name" class="form-control" placeholder="e.g., Building A, Server Room" />
                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Address" class="form-label fw-semibold"></label>
                            <textarea asp-for="Address" rows="3" class="form-control" placeholder="Optional address or details"></textarea>
                            <span asp-validation-for="Address" class="text-danger"></span>
                        </div>

                        <div class="mb-3 d-flex align-items-center">
                            <div class="form-check form-switch">
                                <input asp-for="IsActive" class="form-check-input" />
                                <label asp-for="IsActive" class="form-check-label fw-semibold"></label>
                            </div>
                        </div>

                        <div class="d-flex flex-wrap gap-2 mt-4">
                            <button class="btn btn-primary" type="submit">Create Location</button>
                            <a asp-action="Index" class="btn btn-secondary">Back to List</a>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="card shadow border-0 bg-light">
                    <div class="card-body">
                        <h6 class="fw-bold text-secondary"><i class="fas fa-map-marker-alt me-1"></i> Tip</h6>
                        <p class="small text-muted mb-0">
                            Use clear names like "Building A - Floor 2" to make it easier to find assets later.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}