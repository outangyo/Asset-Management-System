            <!-- Left navbar links -->
            <ul class="navbar-nav">
                <li class="nav-item">
                    <a class="nav-link" data-widget="pushmenu" href="#" role="button"><i class="fas fa-bars"></i></a>
                </li>
                <li class="nav-item d-none d-sm-inline-block">
                    <h1>Asset Management System</h1>
                </li>
            </ul>

            <!-- Right navbar links -->
            @* <ul class="navbar-nav ml-auto">
                <li class="nav-item d-none d-sm-inline-block">
                    <a class="nav-link" asp-controller="Account" asp-action="Login">
                        Login
                    </a>
                </li>
                <li class="nav-item d-none d-sm-inline-block">
                    <a class="nav-link" asp-controller="Account" asp-action="Register">
                        Register
                    </a>
                </li>
            </ul> *@

            <!-- Right navbar links -->
            <ul class="navbar-nav ml-auto">
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <!-- This is for LOGGED-IN users -->
                    <li class="nav-item">
                        <span class="navbar-text">
                            Hello, @User.Identity.Name!
                        </span>
                    </li>
                    <li class="nav-item">
                        <!-- Logout Button -->
                        <form method="post" asp-controller="Account" asp-action="Logout" class="form-inline">
                            <button type="submit" class="nav-link btn btn-link text-dark">Logout</button>
                        </form>
                    </li>
                }
                else
                {
                    <!-- This is for LOGGED-OUT users -->
                    <li class="nav-item d-none d-sm-inline-block">
                        <a class="nav-link" asp-controller="Account" asp-action="Login">
                            Login
                        </a>
                    </li>
                    <li class="nav-item d-none d-sm-inline-block">
                        <a class="nav-link" asp-controller="Account" asp-action="Register">
                            Register
                        </a>
                    </li>
                }
            </ul>
        </nav>
        <!-- /.navbar -->
        <!-- Main Sidebar Container -->
        <aside class="main-sidebar sidebar-dark-primary elevation-4">
            <!-- Brand Logo -->
            <a asp-controller="home" asp-action="index" class="brand-link">
                <img src="~/AdminLTE/dist/img/AdminLTELogo.png" alt="AdminLTE Logo" class="brand-image img-circle elevation-3" style="opacity: .8">
                <span class="brand-text font-weight-light">A.M.S</span>
            </a>

            <!-- Sidebar -->
            <div class="sidebar">
                <!-- Sidebar user panel (optional) -->
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <div class="user-panel mt-3 pb-3 mb-3 d-flex align-items-center">
                        <div class="image">
                            <img src="~/AdminLTE/dist/img/avatar2.png" class="img-circle elevation-2" alt="User Image">
                        </div>
                        <div class="info">
                            <a asp-controller="account" asp-action="profile" class="d-block">@User.Identity.Name</a>
                        </div>
                    </div>
                }
                
                <!-- Sidebar Menu -->
                <nav class="mt-2">
                    <ul class="nav nav-pills nav-sidebar flex-column" data-widget="treeview" role="menu" data-accordion="false">

                        <!-- Dashboard Menu -->
                        <li class="nav-item @IsMenuOpen("home")">
                            <a asp-controller="home" asp-action="index" class="nav-link @IsLinkActive("Home", "Index")">
                                <i class="nav-icon fas fa-tachometer-alt"></i>
                                <p>
                                    Dashboard
                                </p>
                            </a>
                        </li>

                        <!-- Profile Menu -->
                        <li class="nav-item @IsMenuOpen("account")">
                            <a asp-controller="account" asp-action="profile" class="nav-link @IsLinkActive("account", "profile")">
                                <i class="nav-icon fas fa-address-card"></i>
                                <p>
                                    Profile
                                </p>
                            </a>
                        </li>
                        <li class="nav-header">Access</li>

                        <!-- Asset Menu -->
                        <li class="nav-item">
                            <a href="#" class="nav-link">
                                <i class="nav-icon fas fa-th"></i>
                                <p>
                                    Asset
                                    <i class="fas fa-angle-left right"></i>
                                </p>
                            </a>
                            <ul class="nav nav-treeview">
                                <li class="nav-item">
                                    <a href="#" class="nav-link">
                                        <i class="fas fa-plus nav-icon"></i>
                                        <p>Setup 1</p>
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a href="#" class="nav-link">
                                        <i class="fas fa-edit nav-icon"></i>
                                        <p>Setup 2</p>
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a href="#" class="nav-link">
                                        <i class="fas fa-list nav-icon"></i>
                                        <p>Setup 3</p>
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a href="#" class="nav-link">
                                        <i class="fas fa-cog nav-icon"></i>
                                        <p>Setup 4</p>
                                    </a>
                                </li>
                            </ul>
                        </li>

                        <!-- Adminstration Menu -->
                        <li class="nav-item">
                            <a href="#" class="nav-link">
                                <i class="nav-icon fa fa-user-shield"></i>
                                <p>
                                    Administration
                                    <i class="fas fa-angle-left right"></i>
                                </p>
                            </a>
                            <ul class="nav nav-treeview">
                                <li class="nav-item">
                                    <a asp-controller="account" asp-action="AddPermission" class="nav-link">
                                        <i class="fas fa-users-cog nav-icon"></i>
                                        <p>Roles Management</p>
                                    </a>
                                </li>
                            </ul>
                        </li>

                        <!-- Non Secure Page Menu -->
                        <li class="nav-item">
                            <a class="nav-link @IsLinkActive("Home", "NonSecureMethod")" asp-controller="Home" asp-action="NonSecureMethod">
                                <i class="nav-icon fas fa-unlock"></i>
                                <p>Non-Secure Page</p>
                            </a>
                        </li>

                        <!-- Secure Page Menu -->
                        <li class="nav-item">
                            <a class="nav-link @IsLinkActive("Home", "SecureMethod")" asp-controller="Home" asp-action="SecureMethod">
                                <i class="nav-icon fas fa-lock"></i>
                                <p>Secure Page</p>
                            </a>
                        </li>
                    </ul>
                </nav>
                <!-- /.sidebar-menu -->
            </div>
            <!-- /.sidebar -->
        </aside>

        <!-- Content Wrapper. Contains page content -->
        <div class="content-wrapper">
            <!-- Main content -->
            <section class="content">
                <div class="container-fluid">
                    @RenderBody()

                </div><!-- /.container-fluid -->
            </section>
            <!-- /.content -->
        </div>
        <!-- /.content-wrapper -->
        <footer class="main-footer">
            <strong>Copyright &copy; @DateTime.Now.Year <a href="">Designed and Developed By Mo Code</a>.</strong>
            All rights reserved.
            <div class="float-right d-none d-sm-inline-block">
                <b>Version</b> 3.2.0
            </div>
        </footer>

        <!-- Control Sidebar -->
        <aside class="control-sidebar control-sidebar-dark">
            <!-- Control sidebar content goes here -->
        </aside>
        <!-- /.control-sidebar -->
    </div>
    <!-- ./wrapper -->
    <!-- jQuery -->
    <script src="~/AdminLTE/plugins/jquery/jquery.min.js"></script>
    <!-- jQuery UI 1.11.4 -->
