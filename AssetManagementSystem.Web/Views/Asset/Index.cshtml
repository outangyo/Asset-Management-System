@using AssetManagementSystem.Web.Models
@using AssetManagementSystem.Web.Models.Assets
@model PagedResult<AssetListItemViewModel>

@{
    ViewData["Title"] = "Asset Management";
}

<div class="container">
    <!-- Page Header -->
    <div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mb-4 pb-2 border-bottom">
        <div>
            <h1 class="h3 mb-1 fw-bold text-primary">Assets Administration</h1>
            <p class="text-muted mb-0">
                Manage Assets infomation, Add New Asset, and review Asset status.
            </p>
        </div>
        <div>
            <a asp-action="Create" class="btn btn-primary">
                <i class="bi bi-plus-lg me-1"></i>Create New Role
            </a>
        </div>
    </div>

    <!-- Filter/Search Form -->
    <div class="card shadow-sm mb-3">
        <div class="card-body">
            <form asp-action="Index" method="get">
                <div class="row g-3 align-items-end">
                    <div class="col-md-8">
                        <label class="form-label">Search</label>
                        <input type="text" name="Search" class="form-control" placeholder="Search by Code, Name, or Category..." />
                    </div>
                    <div class="col-md-2 justify-content-end">
                        <button type="submit" class="btn btn-info w-100">Apply Filter</button>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <!-- Data Table -->
    <div class="card shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table align-middle mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th>Code</th>
                            <th>Name</th>
                            <th>Category</th>
                            <th>Department</th>
                            <th>Location</th>
                            <th>Registered Date</th>
                            <th>Status</th>
                            <th class="text-end actions-no-wrap">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Items.Any())
                        {
                            <tr>
                                <td colspan="8" class="text-center text-muted py-4">No assets found.</td>
                            </tr>
                        }
                        else
                        {
                            foreach (var asset in Model.Items)
                            {
                                <tr>
                                    <td>@asset.Code</td>
                                    <td>@asset.Name</td>
                                    <td>@asset.Category</td>
                                    <td>@asset.Department</td>
                                    <td>@asset.Location</td>
                                    <td>@asset.DateRegister.ToString("yyyy-MM-dd")</td>
                                    <td>
                                        @if (asset.IsActive)
                                        {
                                            <span class="badge bg-success">Active</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger">Inactive</span>
                                        }
                                    </td>
                                    <td class="text-end actions-no-wrap">
                                        <div class="btn-group btn-group-sm">
                                            <a asp-action="Details" asp-route-id="@asset.Id" class="btn btn-info">View</a>
                                            <a asp-action="Edit" asp-route-id="@asset.Id" class="btn btn-primary">Edit</a>
                                            <button type="button" class="btn btn-danger">Delete</button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Pagination Controls (Optional) -->
    
    @* <div class="mt-3">
        <partial name="_PaginationPartial" model="Model" />
    </div> *@
   
</div>