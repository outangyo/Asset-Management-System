@using AssetManagementSystem.Web.ViewModels.Assets
@model AssetIndexViewModel

@{
    ViewData["Title"] = "Asset Management";
}

<div class="container-fluid px-4">
    <div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mb-4 pb-2 border-bottom">
        <div>
            <h1 class="h3 mb-1 fw-bold text-primary">Assets Administration</h1>
            <p class="text-muted mb-0">
                Manage asset inventory, track status, and view details.
            </p>
        </div>
        <div>
            <a asp-action="Create" class="btn btn-primary">
                <i class="bi bi-plus-lg me-1"></i> Add New Asset
            </a>
        </div>
    </div>

    <form method="get" asp-action="Index" asp-controller="Asset" class="card shadow-sm border-0 mb-4 bg-light">
        <div class="card-body">
            <div class="row g-3 align-items-end">
                <div class="col-md-4">
                    <label class="form-label fw-bold text-secondary small">Search Keyword</label>
                    <div class="input-group">
                        <span class="input-group-text bg-white border-end-0"><i class="bi bi-search text-muted"></i></span>
                        <input name="Search" value="@Model.Filter.Search" class="form-control border-start-0 ps-0"
                               placeholder="Asset Name, Code, Category, etc..." />
                    </div>
                </div>

                <div class="col-md-3">
                    <label class="form-label fw-bold text-secondary small">Status</label>
                    <select name="IsActive" class="form-select">
                        <option value="">All Status</option>
                        <option value="true" selected="@(Model.Filter.IsActive == true)">Active</option>
                        <option value="false" selected="@(Model.Filter.IsActive == false)">Inactive</option>
                    </select>
                </div>

                <div class="col-md-2">
                    <label class="form-label fw-bold text-secondary small">Rows per page</label>
                    <select name="PageSize" class="form-select">
                        @foreach (var size in new[] { 10, 20, 50, 100 })
                        {
                            <option value="@size" selected="@(Model.Filter.PageSize == size)">@size</option>
                        }
                    </select>
                </div>

                <div class="col-md-3 text-md-end">
                    <button class="btn btn-primary me-1" type="submit">
                        <i class="bi bi-funnel me-1"></i> Apply Filter
                    </button>
                    <a asp-action="Index" asp-controller="Asset" class="btn btn-outline-secondary">
                        <i class="bi bi-x-circle"></i> Clear
                    </a>
                </div>
            </div>
        </div>
    </form>

    <div class="card shadow border-0 rounded-3">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light border-bottom">
                        <tr class="text-secondary small text-uppercase">
                            <th class="ps-3 py-3">Code</th>
                            <th class="py-3">Asset Name</th>
                            <th class="py-3">Category</th>
                            <th class="py-3">Location</th>
                            <th class="py-3">Department</th>
                            <th class="py-3">Supplier</th>
                            <th class="py-3">Registered</th>
                            <th class="py-3">Status</th>
                            <th class="text-end pe-3 py-3">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.PagedAssets.Items.Any())
                        {
                            <tr>
                                <td colspan="9" class="text-center text-muted py-5">
                                    <div class="d-flex flex-column align-items-center">
                                        <i class="bi bi-inbox fs-1 mb-2 opacity-50"></i>
                                        <span>No assets found matching your criteria.</span>
                                    </div>
                                </td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var asset in Model.PagedAssets.Items)
                            {
                                <tr>
                                    <td class="ps-3 fw-bold text-primary">@asset.Code</td>
                                    <td>
                                        <span class="fw-semibold text-dark">@asset.Name</span>
                                    </td>
                                    <td><span class="badge bg-light text-dark border">@asset.Category</span></td>
                                    <td class="small text-muted"><i class="bi bi-geo-alt me-1"></i>@asset.Location</td>
                                    <td class="small text-muted">@asset.Department</td>
                                    <td class="small text-muted">@(string.IsNullOrEmpty(asset.SupplierName) || asset.SupplierName == "-" ? "-" : asset.SupplierName)</td>
                                    <td class="small text-muted">@asset.DateRegister.ToString("MMM dd, yyyy")</td>
                                    <td>
                                        @if (asset.IsActive)
                                        {
                                            <span class="badge bg-success-subtle text-success border border-success-subtle rounded-pill">
                                                <i class="bi bi-check-circle me-1"></i>Active
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger-subtle text-danger border border-danger-subtle rounded-pill">
                                                <i class="bi bi-x-circle me-1"></i>Inactive
                                            </span>
                                        }
                                    </td>
                                    <td class="text-end pe-3">
                                        <div class="btn-group btn-group-sm" role="group">
                                            <a asp-action="Details" asp-route-id="@asset.Id"
                                               class="btn btn-outline-info" title="View Details">
                                                <i class="bi bi-eye"></i>
                                            </a>
                                            <a asp-action="Edit" asp-route-id="@asset.Id"
                                               class="btn btn-outline-primary" title="Edit Asset">
                                                <i class="bi bi-pencil"></i>
                                            </a>
                                            <button type="button" class="btn btn-outline-danger"
                                                    data-bs-toggle="modal"
                                                    data-bs-target="#confirmDeleteModal"
                                                    data-asset-id="@asset.Id"
                                                    data-asset-name="@asset.Name"
                                                    title="Delete Asset">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="card-footer bg-white border-top-0 py-3">
            <partial name="_Pager" model="Model.PagedAssets" />
        </div>
    </div>
</div>

// Delete Confirmation Modal
<div class="modal fade" id="confirmDeleteModal" tabindex="-1" aria-labelledby="confirmDeleteLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title" id="confirmDeleteLabel"><i class="bi bi-exclamation-triangle me-2"></i>Confirm Deletion</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4 text-center">
                <div class="mb-3">
                    <i class="bi bi-trash text-danger" style="font-size: 3rem;"></i>
                </div>
                <p class="mb-1 fs-5">Are you sure you want to delete this asset?</p>
                <p class="fw-bold text-dark mb-3" id="deleteAssetNameDisplay"></p>
                <p class="text-muted small">This action cannot be undone and may affect related records.</p>
            </div>
            <div class="modal-footer bg-light justify-content-center border-top-0 pb-4">
                <form id="deleteForm" method="post" asp-action="Delete" asp-controller="Asset">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" id="deleteAssetIdInput" />
                    <button type="button" class="btn btn-secondary px-4 me-2" data-bs-dismiss="modal">Cancel</button>
                    <button class="btn btn-danger px-4" type="submit">Yes, Delete it</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var confirmDeleteModal = document.getElementById('confirmDeleteModal');

            if (confirmDeleteModal) {
                confirmDeleteModal.addEventListener('show.bs.modal', function (event) {
                    var button = event.relatedTarget;
                    var assetId = button.getAttribute('data-asset-id');
                    var assetName = button.getAttribute('data-asset-name');

                    var modalAssetName = confirmDeleteModal.querySelector('#deleteAssetNameDisplay');
                    var modalAssetIdInput = confirmDeleteModal.querySelector('#deleteAssetIdInput');

                    if (modalAssetName) modalAssetName.textContent = assetName;
                    if (modalAssetIdInput) modalAssetIdInput.value = assetId;
                });
            }
        });
    </script>
}