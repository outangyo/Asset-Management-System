@using AssetManagementSystem.Web.ViewModels.Account
@model UserProfileEditViewModel

@{
    ViewData["Title"] = "Edit Profile";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-4" style="min-height: 68vh; max-width: 800px;">
    <div class="row justify-content-center">
        <div class="col-12">

            <div class="text-center mb-4">
                <h2 class="fw-bold text-primary">Edit Your Profile</h2>
                <p class="text-muted">Update your personal information below.</p>
            </div>

            <div class="card shadow-lg border-0 rounded-4" style="background: linear-gradient(110deg, #ffffff 60%, #f0f7ff 100%);">
                <div class="card-body p-5">

                    <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-3 shadow-sm mb-4"></div>

                    <form id="editProfileForm" asp-action="EditProfile" method="post" novalidate>

                        <div class="bg-light bg-opacity-50 p-3 rounded-3 mb-4 border border-light">
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label class="form-label text-secondary small fw-bold text-uppercase">Username</label>
                                    <div class="form-control-plaintext fw-bold text-dark px-2">@Model.Username</div>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label text-secondary small fw-bold text-uppercase">Email Address</label>
                                    <div class="form-control-plaintext fw-bold text-dark px-2">@Model.Email</div>
                                </div>
                            </div>
                        </div>

                        <hr class="my-4 text-muted opacity-25" />

                        <div class="row g-4">
                            <div class="col-md-6">
                                <label asp-for="FirstName" class="form-label fw-semibold"></label>
                                <div class="input-group">
                                    <span class="input-group-text bg-white text-primary border-end-0"><i class="fas fa-user"></i></span>
                                    <input asp-for="FirstName" class="form-control border-start-0 ps-0" placeholder="Enter first name" />
                                </div>
                                <span asp-validation-for="FirstName" class="text-danger small mt-1 d-block"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="LastName" class="form-label fw-semibold"></label>
                                <div class="input-group">
                                    <span class="input-group-text bg-white text-primary border-end-0"><i class="fas fa-user"></i></span>
                                    <input asp-for="LastName" class="form-control border-start-0 ps-0" placeholder="Enter last name" />
                                </div>
                                <span asp-validation-for="LastName" class="text-danger small mt-1 d-block"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="PhoneNumber" class="form-label fw-semibold"></label>
                                <div class="input-group">
                                    <span class="input-group-text bg-white text-primary border-end-0"><i class="fas fa-phone"></i></span>
                                    <input asp-for="PhoneNumber" class="form-control border-start-0 ps-0" placeholder="Enter phone number" />
                                </div>
                                <span asp-validation-for="PhoneNumber" class="text-danger small mt-1 d-block"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="DateOfBirth" class="form-label fw-semibold"></label>
                                <div class="input-group">
                                    <span class="input-group-text bg-white text-primary border-end-0"><i class="fas fa-calendar-alt"></i></span>
                                    <input asp-for="DateOfBirth" type="date" class="form-control border-start-0 ps-0" />
                                </div>
                                <span asp-validation-for="DateOfBirth" class="text-danger small mt-1 d-block"></span>
                            </div>
                        </div>

                        <div class="d-flex justify-content-center gap-3 mt-5">
                            <a asp-action="Profile" class="btn btn-outline-secondary px-4 py-2 rounded-pill fw-semibold">
                                Cancel
                            </a>
                            <button type="button" class="btn btn-primary px-5 py-2 rounded-pill fw-bold shadow-sm"
                                    data-bs-toggle="modal" data-bs-target="#confirmSaveModal">
                                <i class="fas fa-save me-2"></i> Save Changes
                            </button>
                        </div>

                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

// modal pop up for save confirm
<div class="modal fade" id="confirmSaveModal" tabindex="-1" aria-labelledby="confirmSaveLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title" id="confirmSaveLabel"><i class="fas fa-question-circle me-2"></i>Confirm Changes</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4 text-center">
                <div class="mb-3">
                    <i class="fas fa-user-edit text-primary" style="font-size: 3rem;"></i>
                </div>
                <p class="mb-1 fs-5">Are you sure you want to save these changes?</p>
                <p class="text-muted small">Your profile information will be updated immediately.</p>
            </div>
            <div class="modal-footer bg-light justify-content-center border-top-0 pb-4">
                <button type="button" class="btn btn-secondary px-4 me-2" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary px-4" id="confirmSaveBtn">Yes, Save Changes</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            // เมื่อกดปุ่ม "Yes, Save Changes" ใน Modal
            document.getElementById('confirmSaveBtn').addEventListener('click', function () {
                // สั่ง Submit ฟอร์มที่มี ID 'editProfileForm'
                document.getElementById('editProfileForm').submit();
            });
        });
    </script>
}