@using AssetManagementSystem.Web.ViewModels.Assets
@model AssetEditViewModel

@{
    ViewData["Title"] = "Edit Asset";
}

<div class="container">
    <!-- Page Header -->
    <div class="gap-2 mb-4 pb-2 border-bottom">
        <h1 class="h3 fw-bold text-primary mb-1">Edit Asset</h1>
        <p class="text-muted mb-0">Edit asset details informtaion.</p>
    </div>

    <form asp-action="Edit" method="post" novalidate>
        <input type="hidden" asp-for="Id" />
        <div class="row g-4">
            <!-- Left Column: Main Form -->
            <div class="col-lg-8">
                <div class="card shadow-sm border-0 h-100">
                    <div class="card-body">
                        <!-- Validation Summary (optional but recommended) -->
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                        <div class="row">
                            <!-- Code -->
                            <div class="mb-3 col-md-6">
                                <label asp-for="Code" class="form-label fw-semibold"></label>
                                <input asp-for="Code" class="form-control" placeholder="e.g., LAP-001, MON-DELL-24" />
                                <span asp-validation-for="Code" class="text-danger"></span>
                            </div>

                            <!-- Name -->
                            <div class="mb-3 col-md-6">
                                <label asp-for="Name" class="form-label fw-semibold"></label>
                                <input asp-for="Name" class="form-control" placeholder="e.g., Dell Latitude 5420" />
                                <span asp-validation-for="Name" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="row">
                            <!-- Category -->
                            <div class="mb-3 col-md-4">
                                <label asp-for="CategoryId" class="form-label fw-semibold"></label>
                                <select asp-for="CategoryId" asp-items="Model.Categories" class="form-select">
                                    <option value="">-- Select --</option>
                                </select>
                                <span asp-validation-for="CategoryId" class="text-danger"></span>
                            </div>

                            <!-- Department -->
                            <div class="mb-3 col-md-4">
                                <label asp-for="DepartmentId" class="form-label fw-semibold"></label>
                                <select asp-for="DepartmentId" asp-items="Model.Departments" class="form-select">
                                    <option value="">-- Select --</option>
                                </select>
                                <span asp-validation-for="DepartmentId" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="row">
                            <!-- Location -->
                            <div class="mb-3 col-md-4">
                                <label asp-for="LocationId" class="form-label fw-semibold"></label>
                                <select asp-for="LocationId" asp-items="Model.Locations" class="form-select">
                                    <option value="">-- Select --</option>
                                </select>
                                <span asp-validation-for="LocationId" class="text-danger"></span>
                            </div>

                            <!-- Supplier -->
                            <div class="mb-3 col-md-6">
                                <label asp-for="SupplierId" class="form-label fw-semibold"></label>
                                <select asp-for="SupplierId" asp-items="Model.Suppliers" class="form-select">
                                    <option value="">-- Select Supplier (Optional) --</option>
                                </select>
                                <span asp-validation-for="SupplierId" class="text-danger"></span>
                            </div>
                        </div>

                        <!-- Description -->
                        <div class="mb-3">
                            <label asp-for="Description" class="form-label fw-semibold"></label>
                            <textarea asp-for="Description" rows="3" class="form-control" placeholder="Describe the asset (e.g., specifications, condition)"></textarea>
                            <span asp-validation-for="Description" class="text-danger"></span>
                        </div>

                        <!-- Note -->
                        <div class="mb-3">
                            <label asp-for="Note" class="form-label fw-semibold"></label>
                            <textarea asp-for="Note" rows="2" class="form-control" placeholder="Any additional notes or comments"></textarea>
                            <span asp-validation-for="Note" class="text-danger"></span>
                        </div>

                        <div class="row">
                            <!-- Registered Date -->
                            <div class="mb-3 col-md-6">
                                <label asp-for="DateRegister" class="form-label fw-semibold"></label>
                                <input asp-for="DateRegister" type="date" class="form-control" />
                                <span asp-validation-for="DateRegister" class="text-danger"></span>
                            </div>

                            <!-- Active Status -->
                            <div class="mb-3 col-md-6 d-flex align-items-center">
                                <div class="form-check form-switch mt-3">
                                    <input asp-for="IsActive" class="form-check-input" />
                                    <label asp-for="IsActive" class="form-check-label fw-semibold"></label>
                                </div>
                            </div>
                        </div>

                        <!-- Actions -->
                        <div class="d-flex flex-wrap gap-2">
                            <button class="btn btn-primary" type="submit">Save Changes</button>
                            <button class="btn btn-dark" type="reset">Reset</button>
                            <a asp-action="Index" class="btn btn-info">Back to List</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}