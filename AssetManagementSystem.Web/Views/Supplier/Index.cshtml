@using AssetManagementSystem.Web.ViewModels
@using AssetManagementSystem.Web.ViewModels.Suppliers
@model SupplierIndexViewModel

@{
    ViewData["Title"] = "Supplier Management";
}

<div class="container">
    <div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mb-4 pb-2 border-bottom">
        <div>
            <h1 class="h3 mb-1 fw-bold text-primary">Suppliers Administration</h1>
            <p class="text-muted mb-0">
                Manage supplier information, add new suppliers, and review their status.
            </p>
        </div>
        <div>
            <a asp-action="Create" class="btn btn-primary">
                <i class="bi bi-plus-lg me-1"></i>Add New Supplier
            </a>
        </div>
    </div>

    <form method="get" asp-action="Index" asp-controller="Supplier" class="row g-2 align-items-end mb-3">
        <div class="col-md-4">
            <label class="form-label">Search</label>
            <input name="Search" value="@Model.Filter.Search" class="form-control"
                   placeholder="Search by name, code, or contact" />
        </div>
        <div class="col-md-3">
            <label class="form-label">Status</label>
            <select name="IsActive" class="form-select">
                <option value="">All Status</option>
                <option value="true" selected="@(Model.Filter.IsActive == true)">Active</option>
                <option value="false" selected="@(Model.Filter.IsActive == false)">Inactive</option>
            </select>
        </div>
        <div class="col-md-3">
            <label class="form-label">Page Size</label>
            <select name="PageSize" class="form-select">
                @foreach (var size in new[] { 5, 10, 20, 50 })
                {
                    <option value="@size" selected="@(Model.Filter.PageSize == size)">@size / page</option>
                }
            </select>
        </div>

        <div class="col-md-2 d-grid d-sm-flex gap-2">
            <button class="btn btn-primary" type="submit">
                <i class="bi bi-funnel me-1"></i> Apply
            </button>
            <a asp-action="Index" asp-controller="Supplier" class="btn btn-info">
                <i class="bi bi-x-circle me-1"></i> Clear
            </a>
        </div>
    </form>

    <div class="card shadow border-0 rounded">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table align-middle mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th>Supplier Code</th>
                            <th>Name</th>
                            <th>Contact Name</th>
                            <th>Email</th>
                            <th>Phone</th>
                            <th>Status</th>
                            <th class="text-center actions-no-wrap">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.PagedSuppliers.Items.Any())
                        {
                            <tr>
                                <td colspan="7" class="text-center text-muted py-4">No supplier found.</td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var supplier in Model.PagedSuppliers.Items)
                            {
                                <tr>
                                    <td>@supplier.SupplierCode</td>
                                    <td>@supplier.Name</td>
                                    <td>@supplier.ContactName</td>
                                    <td>@supplier.ContactEmail</td>
                                    <td>@supplier.ContactPhone</td>
                                    <td>
                                        @if (supplier.IsActive)
                                        {
                                            <span class="badge bg-success">Active</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger">Inactive</span>
                                        }
                                    </td>
                                    <td class="text-end actions-no-wrap">
                                        <a asp-action="Details" asp-route-id="@supplier.Id" class="btn btn-sm btn-outline-info me-2">Details</a>
                                        <a asp-action="Edit" asp-route-id="@supplier.Id" class="btn btn-sm btn-outline-primary me-2">Edit</a>
                                        <button class="btn btn-sm btn-outline-danger" type="button"
                                                data-bs-toggle="modal"
                                                data-bs-target="#confirmDeleteModal"
                                                data-supplier-id="@supplier.Id"
                                                data-supplier-name="@supplier.Name">
                                            Delete
                                        </button>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="mt-3">
        <partial name="_Pager" model="Model.PagedSuppliers" />
    </div>
</div>

<div class="modal fade" id="confirmDeleteModal" tabindex="-1" aria-labelledby="confirmDeleteLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="confirmDeleteLabel">Delete Supplier</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                Are you sure you want to delete the supplier <strong id="deleteSupplierName"></strong>?
                <div class="text-muted small mt-2">This action cannot be undone.</div>
            </div>
            <div class="modal-footer">
                <form id="deleteForm" method="post" asp-action="Delete" asp-controller="Supplier">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" id="deleteSupplierId" />
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button class="btn btn-danger" type="submit">Delete</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        // Wait for the document to be fully loaded
        document.addEventListener('DOMContentLoaded', function () {
            // Get the modal element
            var confirmDeleteModal = document.getElementById('confirmDeleteModal');

            // Add an event listener for when the modal is about to be shown
            confirmDeleteModal.addEventListener('show.bs.modal', function (event) {
                // Get the button that triggered the modal
                var button = event.relatedTarget;

                // Extract info from data-* attributes
                var supplierId = button.getAttribute('data-supplier-id');
                var supplierName = button.getAttribute('data-supplier-name');

                // Get elements inside the modal to update
                var modalSupplierName = confirmDeleteModal.querySelector('#deleteSupplierName');
                var modalSupplierIdInput = confirmDeleteModal.querySelector('#deleteSupplierId');

                // Update the modal's content
                modalSupplierName.textContent = supplierName;
                modalSupplierIdInput.value = supplierId;
            });
        });
    </script>
}