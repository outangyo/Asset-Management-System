@using AssetManagementSystem.Web.Models
@using AssetManagementSystem.Web.Models.Assets
@model AssetIndexViewModel

@{
    ViewData["Title"] = "Asset Management";
}

<div class="container">
    <!-- Page Header -->
    <div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mb-4 pb-2 border-bottom">
        <div>
            <h1 class="h3 mb-1 fw-bold text-primary">Assets Administration</h1>
            <p class="text-muted mb-0">
                Manage Assets infomation, Add New Asset, and review Asset status.
            </p>
        </div>
        <div>
            <a asp-action="Create" class="btn btn-primary">
                <i class="bi bi-plus-lg me-1"></i>Add New Asset
            </a>
        </div>
    </div>

    <!-- Filter/Search Form -->
    <form method="get" asp-action="Index" asp-controller="asset" class="row g-2 align-items-end mb-3">
        <div class="col-md-4">
            <label class="form-label">Search</label>
            <input name="Search" value="@Model.Filter.Search" class="form-control"
                   placeholder="Search by name or description..." />
        </div>
        <div class="col-md-3">
            <label class="form-label">Status</label>
            <select name="IsActive" class="form-select">
                <option value="">All Status</option>
                <option value="true" selected="@(Model.Filter.IsActive == true)">Active</option>
                <option value="false" selected="@(Model.Filter.IsActive == false)">Inactive</option>
            </select>
        </div>
        <div class="col-md-3">
            <label class="form-label">Page Size</label>
            <select name="PageSize" class="form-select">
                @foreach (var size in new[] { 5, 10, 20, 50 })
                {
                    <option value="@size" selected="@(Model.Filter.PageSize == size)">@size / page</option>
                }
            </select>
        </div>
        <div class="col-md-2 d-grid d-sm-flex gap-2">
            <button class="btn btn-primary" type="submit">
                <i class="bi bi-funnel me-1"></i> Apply
            </button>
            <!-- Clear = go to Index without query string -->
            <a asp-action="Index" class="btn btn-info">
                <i class="bi bi-x-circle me-1"></i> Clear
            </a>
        </div>
    </form>

    <!-- Data Table -->
    <div class="card shadow border-0 rounded">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table align-middle mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th>Code</th>
                            <th>Name</th>
                            <th>Category</th>
                            <th>Department</th>
                            <th>Location</th>
                            <th>Registered Date</th>
                            <th>Status</th>
                            <th class="text-center actions-no-wrap">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.PagedAssets.Items.Any())
                        {
                            <tr>
                                <td colspan="8" class="text-center text-muted py-4">No asset found.</td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var asset in Model.PagedAssets.Items)
                            {
                                <tr>
                                    <td>@asset.Code</td>
                                    <td>@asset.Name</td>
                                    <td>@asset.Category</td>
                                    <td>@asset.Department</td>
                                    <td>@asset.Location</td>
                                    <td>@asset.DateRegister.ToString("yyyy-MM-dd")</td>
                                    <td>
                                        @if (asset.IsActive)
                                        {
                                            <span class="badge bg-success">Active</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger">Inactive</span>
                                        }
                                    </td>
                                    <td class="text-end actions-no-wrap">
                                            <a asp-action="Details" asp-route-id="@asset.Id" class="btn btn-sm btn-outline-info me-2">Details</a>
                                            <a asp-action="Edit" asp-route-id="@asset.Id" class="btn btn-sm btn-outline-primary me-2">Edit</a>
                                            <button type="button" class="btn btn-sm btn-outline-danger">Delete</button>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Pagination Controls (Optional) -->
    
    @* <div class="mt-3">
        <partial name="_PaginationPartial" model="Model" />
    </div> *@
   
</div>